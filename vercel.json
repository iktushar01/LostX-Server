{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "prisma generate",
  "crons": [
    {
      "path": "/api/cron/expiry",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "index.ts": {
      "maxDuration": 60,
      "includeFiles": [
        "src/generated/prisma/**",
        "src/app/templates/**"
      ]
    }
  }
}
