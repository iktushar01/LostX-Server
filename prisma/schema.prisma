generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (better-auth) ───────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                  String     @id
  name                String
  email               String     @unique
  emailVerified       Boolean    @default(false)
  role                Role       @default(USER)
  status              UserStatus @default(ACTIVE)
  needPasswordChange  Boolean    @default(false)
  isDeleted           Boolean    @default(false)
  deletedAt           DateTime?
  image               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  lastLogin           DateTime?
  lastIpAddress       String?
  lastUserAgent       String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  accounts            Account[]
  sessions            Session[]
  lostItems           LostItem[]
  foundItems          FoundItem[]
  claims              Claim[]
  claimMessages       ClaimMessage[]
  notifications       Notification[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Lost & Found ───────────────────────────────────────────────────────────

enum ItemCategory {
  ID_CARD
  WALLET
  PHONE
  LAPTOP
  KEYS
  BAG
  BOOK
  OTHER
}

enum LostItemStatus {
  OPEN
  MATCHED
  RECOVERED
}

enum FoundItemStatus {
  AVAILABLE
  CLAIMED
  RETURNED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_PENDING
  ITEM_RETURNED
  MATCH_FOUND
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model LostItem {
  id                   String         @id @default(cuid())
  title                String
  description          String
  category             ItemCategory
  imageUrl             String?
  location             String
  dateLost             DateTime
  status               LostItemStatus @default(OPEN)
  isFeatured           Boolean        @default(false)
  userId               String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  verificationQuestion String?
  verificationAnswer     String?
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims               Claim[]

  @@index([category])
  @@index([status])
  @@index([userId])
  @@map("lost_items")
}

model FoundItem {
  id          String          @id @default(cuid())
  title       String
  description String
  category    ItemCategory
  imageUrl    String?
  location    String
  dateFound   DateTime
  status      FoundItemStatus @default(AVAILABLE)
  isFeatured  Boolean         @default(false)
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims      Claim[]

  @@index([category])
  @@index([status])
  @@index([userId])
  @@map("found_items")
}

model Claim {
  id          String      @id @default(cuid())
  foundItemId String
  userId      String
  answer      String
  status      ClaimStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lostItemId  String?
  foundItem   FoundItem   @relation(fields: [foundItemId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lostItem    LostItem?   @relation(fields: [lostItemId], references: [id], onDelete: SetNull)
  messages    ClaimMessage[]

  @@index([foundItemId])
  @@index([userId])
  @@index([status])
  @@index([lostItemId])
  @@map("claims")
}

model ClaimMessage {
  id        String   @id @default(cuid())
  claimId   String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([senderId])
  @@index([createdAt])
  @@map("claim_messages")
}
