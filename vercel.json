{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/cron/expiry",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "src/server.ts": {
      "maxDuration": 60,
      "includeFiles": "src/{generated/prisma/**,app/templates/**}"
    }
  }
}
