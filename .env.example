# Server
PORT=5000
NODE_ENV=development
BETTER_AUTH_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
# Comma-separated extra origins (e.g. Vercel preview URLs)
# ALLOWED_ORIGINS=https://lostx-client.vercel.app,https://lostx-client-git-main.vercel.app
DATABASE_URL=

# Auth
BETTER_AUTH_SECRET=
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=7d
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1d

# Email
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EXPIRE_OTP_TIME=10m

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
IMGBB_API_KEY=

# Seed
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# OpenRouter / Chatbot
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
CHATBOT_TOP_K=5
CHATBOT_MIN_SIMILARITY=0.55
CHATBOT_EMBEDDING_DIMENSION=2048

# Matching & lifecycle
AUTO_APPROVE_MATCH_THRESHOLD=85
AI_AUTO_APPROVE_CONFIDENCE=80
ITEM_EXPIRY_DAYS=90
DUPLICATE_REPORT_WINDOW_HOURS=24

# Privacy — encrypt private item details (openssl rand -hex 32)
ENCRYPTION_KEY=

# Vercel cron (generate with: openssl rand -hex 32)
CRON_SECRET=
