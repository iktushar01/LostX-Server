{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run vercel-build",
  "functions": {
    "src/server.ts": {
      "maxDuration": 60,
      "includeFiles": "src/{generated/prisma/**,app/templates/**}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/expiry",
      "schedule": "0 0 * * *"
    }
  ]
}
