generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum ItemCategory {
  ID_CARD
  WALLET
  PHONE
  LAPTOP
  KEYS
  BAG
  BOOK
  OTHER
}

enum LostItemStatus {
  OPEN
  MATCHED
  RECOVERED
}

enum FoundItemStatus {
  AVAILABLE
  CLAIMED
  RETURNED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String     @id @default(uuid())
  name                String
  email               String     @unique
  emailVerified       Boolean    @default(false)
  image               String?
  role                UserRole   @default(USER)
  status              UserStatus @default(ACTIVE)
  needPasswordChange  Boolean    @default(false)
  isDeleted           Boolean    @default(false)
  deletedAt           DateTime?
  lastLogin           DateTime?
  lastIpAddress       String?
  lastUserAgent       String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  accounts   Account[]
  sessions   Session[]
  lostItems  LostItem[]
  foundItems FoundItem[]
  claims     Claim[]

  @@map("users")
}

model LostItem {
  id                   String         @id @default(uuid())
  title                String
  description          String         @db.Text
  category             ItemCategory
  imageUrl             String?
  location             String
  dateLost             DateTime
  status               LostItemStatus @default(OPEN)
  verificationQuestion String?
  verificationAnswer   String?
  userId               String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims Claim[]

  @@index([category])
  @@index([status])
  @@index([userId])
  @@map("lost_items")
}

model FoundItem {
  id          String          @id @default(uuid())
  title       String
  description String          @db.Text
  category    ItemCategory
  imageUrl    String?
  location    String
  dateFound   DateTime
  status      FoundItemStatus @default(AVAILABLE)
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims Claim[]

  @@index([category])
  @@index([status])
  @@index([userId])
  @@map("found_items")
}

model Claim {
  id          String      @id @default(uuid())
  foundItemId String
  lostItemId  String?
  userId      String
  answer      String      @db.Text
  status      ClaimStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  foundItem FoundItem  @relation(fields: [foundItemId], references: [id], onDelete: Cascade)
  lostItem  LostItem?  @relation(fields: [lostItemId], references: [id], onDelete: SetNull)

  @@index([foundItemId])
  @@index([lostItemId])
  @@index([userId])
  @@index([status])
  @@map("claims")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
