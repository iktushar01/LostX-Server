{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --prod=false",
  "buildCommand": "pnpm run build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": [
        "dist/**",
        "src/app/templates/**"
      ]
    }
  },
  "crons": [
    {
      "path": "/api/cron/expiry",
      "schedule": "0 0 * * *"
    }
  ]
}
