generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (better-auth) ───────────────────────────────────────────────────────

enum Role {
  USER
  STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model User {
  id                  String     @id
  name                String
  email               String     @unique
  emailVerified       Boolean    @default(false)
  role                Role       @default(USER)
  status              UserStatus @default(ACTIVE)
  needPasswordChange  Boolean    @default(false)
  isDeleted           Boolean    @default(false)
  deletedAt           DateTime?
  image               String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  lastLogin           DateTime?
  lastIpAddress       String?
  lastUserAgent       String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  accounts            Account[]
  sessions            Session[]
  lostItems           LostItem[]
  foundItems          FoundItem[]
  claims              Claim[]
  claimMessages       ClaimMessage[]
  notifications       Notification[]
  chatLogs            ChatLog[]
  auditLogs           AuditLog[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Lost & Found ───────────────────────────────────────────────────────────

enum ItemCategory {
  ID_CARD
  WALLET
  PHONE
  LAPTOP
  KEYS
  BAG
  BOOK
  OTHER
}

enum LostItemStatus {
  OPEN
  MATCHED
  RECOVERED
  EXPIRED
  CANCELLED
}

enum FoundItemStatus {
  AVAILABLE
  CLAIMED
  RETURNED
  EXPIRED
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_PENDING
  ITEM_RETURNED
  MATCH_FOUND
}

enum AuditAction {
  CLAIM_APPROVED
  CLAIM_REJECTED
  CLAIM_AUTO_APPROVED
  CLAIM_RECEIVED_CONFIRMED
  ITEM_CREATED
  ITEM_DELETED
  ITEM_FEATURED
  ITEM_RETURNED
  ITEM_EXPIRED
  ITEM_REGISTERED_BY_STAFF
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model LostItem {
  id                   String         @id @default(cuid())
  title                String
  description          String
  privateDescription   String?
  category             ItemCategory
  imageUrl             String?
  location             String
  building             String?
  floor                String?
  room                 String?
  dateLost             DateTime
  status               LostItemStatus @default(OPEN)
  isFeatured           Boolean        @default(false)
  showImagePublic      Boolean        @default(true)
  showDescriptionPublic Boolean       @default(true)
  showLocationPublic   Boolean        @default(false)
  userId               String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  verificationQuestion String?
  verificationAnswer   String?
  embedding            Unsupported("vector")?
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims               Claim[]

  @@index([category])
  @@index([status])
  @@index([userId])
  @@map("lost_items")
}

model FoundItem {
  id                    String          @id @default(cuid())
  title                 String
  description           String
  privateDescription    String?
  category              ItemCategory
  imageUrl              String?
  location              String
  building              String?
  floor                 String?
  room                  String?
  dateFound             DateTime
  status                FoundItemStatus @default(AVAILABLE)
  isFeatured            Boolean         @default(false)
  showImagePublic       Boolean         @default(true)
  showDescriptionPublic Boolean         @default(true)
  showLocationPublic    Boolean         @default(false)
  embedding             Unsupported("vector")?
  userId                String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  claims                Claim[]

  @@index([category])
  @@index([status])
  @@index([userId])
  @@map("found_items")
}

model Claim {
  id                  String      @id @default(cuid())
  foundItemId         String
  userId              String
  answer              String
  status              ClaimStatus @default(PENDING)
  autoApproved        Boolean     @default(false)
  matchScore          Int?
  aiQuestions         Json?
  aiAnswers           Json?
  aiConfidence        Int?
  aiRecommendation    String?
  receivedConfirmedAt DateTime?
  handoffCode         String?     @unique
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  lostItemId          String?
  foundItem           FoundItem   @relation(fields: [foundItemId], references: [id], onDelete: Cascade)
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lostItem            LostItem?   @relation(fields: [lostItemId], references: [id], onDelete: SetNull)
  messages            ClaimMessage[]

  @@unique([foundItemId, userId])
  @@index([foundItemId])
  @@index([userId])
  @@index([status])
  @@index([lostItemId])
  @@map("claims")
}

model ClaimMessage {
  id        String   @id @default(cuid())
  claimId   String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  claim     Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([senderId])
  @@index([createdAt])
  @@map("claim_messages")
}

model ChatLog {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  answer    String
  matches   Json
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("chat_logs")
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  action     AuditAction
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime    @default(now())
  actor      User        @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
